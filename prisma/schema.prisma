generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id Int @id @default(autoincrement())

  fullName String
  email    String    @unique
  password String
  role     UserRole  @default(USER)
  verified DateTime?

  phone         String?   @unique
  phoneVerified DateTime?

  provider   String?
  providerId String?

  cart             Cart?
  orders           Order[]
  verificationCode VerificationCode?
  promoRedemptions PromoRedemption[]

  blacklisted Boolean @default(false)
  adminNote   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id Int @id @default(autoincrement())

  name      String
  sortOrder Int    @default(0)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder, id])
}

model Product {
  id Int @id @default(autoincrement())

  name     String
  imageUrl String

  active    Boolean @default(true)
  sortOrder Int     @default(0)

  description String?
  composition String?

  calories Int?
  proteins Float?
  fats     Float?
  carbs    Float?

  allergens String[] @default([])
  badges    String[] @default([])

  stopUntil DateTime?

  category   Category @relation(fields: [categoryId], references: [id])
  categoryId Int

  ingredients Ingredient[]

  items ProductItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId, sortOrder, id])
  @@index([active])
  @@index([stopUntil])
}

model ProductItem {
  id Int @id @default(autoincrement())

  price     Int
  size      Int?
  pizzaType Int?

  product   Product @relation(fields: [productId], references: [id])
  productId Int

  cartItems CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ingredient {
  id Int @id @default(autoincrement())

  name     String
  imageUrl String
  price    Int

  products  Product[]
  cartItems CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Cart {
  id Int @id @default(autoincrement())

  user   User? @relation(fields: [userId], references: [id])
  userId Int?  @unique

  items CartItem[]

  totalAmount Int @default(0)

  token String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id Int @id @default(autoincrement())

  cart   Cart @relation(fields: [cartId], references: [id])
  cartId Int

  productItem   ProductItem @relation(fields: [productItemId], references: [id])
  productItemId Int

  ingredients Ingredient[]

  quantity Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id Int @id @default(autoincrement())

  user   User? @relation(fields: [userId], references: [id])
  userId Int?

  totalAmount    Int
  discountAmount Int     @default(0)
  promo          Promo?  @relation(fields: [promoId], references: [id])
  promoId        Int?
  promoCode      String?

  token       String
  status      OrderStatus
  paymentId   String?

  fulfillmentStatus OrderFulfillmentStatus @default(NEW)
  adminNote         String?

  items Json

  fullName String
  email    String
  phone    String
  address  String
  comment  String?

  events     OrderEvent[]
  redemption PromoRedemption?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderEvent {
  id Int @id @default(autoincrement())

  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId Int

  kind        OrderEventKind
  payload     Json?
  actorEmail  String?

  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
}

model VerificationCode {
  id Int @id @default(autoincrement())

  user   User @relation(fields: [userId], references: [id])
  userId Int  @unique

  code String

  createdAt DateTime @default(now())
}

model OtpCode {
  id Int @id @default(autoincrement())

  phone     String
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  consumed  Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([phone, createdAt])
}

model Story {
  id              Int    @id @default(autoincrement())
  previewImageUrl String

  items StoryItem[]

  createdAt DateTime @default(now())
}

model StoryItem {
  id Int @id @default(autoincrement())

  storyId Int
  story   Story @relation(fields: [storyId], references: [id])

  sourceUrl String

  createdAt DateTime @default(now())
}

model Promo {
  id Int @id @default(autoincrement())

  code           String    @unique
  kind           PromoKind
  valueOff       Int       @default(0)

  minOrderAmount Int?
  maxDiscount    Int?

  validFrom  DateTime?
  validUntil DateTime?

  usageLimit   Int?
  perUserLimit Int?

  active      Boolean @default(true)
  description String?

  redemptions PromoRedemption[]
  orders      Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
  @@index([validFrom, validUntil])
}

model PromoRedemption {
  id Int @id @default(autoincrement())

  promo   Promo @relation(fields: [promoId], references: [id])
  promoId Int

  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId Int   @unique

  user   User? @relation(fields: [userId], references: [id])
  userId Int?

  appliedAmount Int
  code          String

  createdAt DateTime @default(now())

  @@index([promoId, createdAt])
  @@index([userId, promoId])
}

enum OrderStatus {
  PENDING
  SUCCEEDED
  CANCELLED
}

enum PromoKind {
  PERCENT
  FIXED
  FREE_DELIVERY
}

enum OrderFulfillmentStatus {
  NEW
  CONFIRMED
  COOKING
  READY
  DELIVERING
  DELIVERED
  CANCELLED
  REFUNDED
}

enum OrderEventKind {
  PAYMENT_STATUS_CHANGED
  FULFILLMENT_STATUS_CHANGED
  NOTE
  OTHER
}

enum UserRole {
  USER
  ADMIN
  OWNER
  OPERATOR
  MARKETER
}
